{
  "version": 2,
  "rewrites": [
    { "source": "/api/chat", "destination": "/api/chat" },
    { "source": "/api/image", "destination": "/api/image" },
    { "source": "/(.*)", "destination": "/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
